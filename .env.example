# F1362: Environment Variables Documentation

# Vapi.ai Configuration
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
VAPI_TEST_MODE=false

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# F1186: Twilio Test Mode - Use test credentials to avoid SMS charges
TWILIO_TEST_MODE=false
TWILIO_TEST_ACCOUNT_SID=your_test_account_sid
TWILIO_TEST_AUTH_TOKEN=your_test_auth_token
TWILIO_TEST_PHONE_NUMBER=+15005550006

# Cal.com Configuration
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_BASE_URL=https://api.cal.com/v1

# F0306: Cal.com User ID - For multi-user setups
CALCOM_USER_ID=your_calcom_user_id

# F1187: Cal.com Sandbox - Use sandbox API for testing
CALCOM_SANDBOX=false
CALCOM_SANDBOX_URL=https://api-sandbox.cal.com/v1

# F192-199: Scheduling Provider Abstraction
# Supported providers: calcom, easyappointments, google-calendar
SCHEDULING_PROVIDER=calcom
SCHEDULING_API_KEY=your_scheduling_api_key
SCHEDULING_API_URL=https://api.example.com
SCHEDULING_EVENT_TYPE_ID=1
SCHEDULING_SERVICE_ID=1

# Easy!Appointments Configuration (if using SCHEDULING_PROVIDER=easyappointments)
EASYAPPOINTMENTS_API_URL=https://your-domain.com/easyappointments
EASYAPPOINTMENTS_API_KEY=your_easyappointments_api_key
EASYAPPOINTMENTS_SERVICE_ID=1

# Google Calendar Configuration (if using SCHEDULING_PROVIDER=google-calendar)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# F1188: Supabase Test Mode - Use separate test database
SUPABASE_TEST_MODE=false
SUPABASE_TEST_URL=https://your-test-project.supabase.co
SUPABASE_TEST_ANON_KEY=your_test_anon_key
SUPABASE_TEST_SERVICE_KEY=your_test_service_key

# ElevenLabs (Optional - for custom voices)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (Optional - if using custom LLM endpoint)
OPENAI_API_KEY=your_openai_key_here

# F1132: JWT Secret Rotation - Support multiple secrets during rotation
JWT_SECRET=your_jwt_secret_here
JWT_PREVIOUS_SECRETS=old-secret-1,old-secret-2
JWT_ALGORITHM=HS256

# Alternative naming (NextAuth compatible)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_PREVIOUS_SECRETS=old-secret-1,old-secret-2

# F0859, F0860, F0323: Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Voice AI Agent <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# F0859, F0860: Cron Job Authentication
CRON_SECRET=your_cron_secret_here

# Feature Flags
ENABLE_AUTH=false
ENABLE_ANALYTICS=true
